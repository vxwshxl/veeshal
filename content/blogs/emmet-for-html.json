gress wheel (shared fixed chrome) -->\n<div class=\"grain\" aria-hidden=\"true\"></div>\n<div class=\"cursor-dot\" aria-hidden=\"true\"></div>\n<div class=\"cursor-ring\" aria-hidden=\"true\"></div>\n\n<button class=\"scroll-wheel\" aria-label=\"Back to top\">\n    <svg viewBox=\"0 0 100 100\">\n        <circle cx=\"50\" cy=\"50\" r=\"44\" fill=\"rgba(17,17,16,0.85)\" />\n        <g class=\"sw-rotor\">\n            <circle cx=\"50\" cy=\"50\" r=\"36\" fill=\"none\" stroke=\"#3a3a3e\" stroke-width=\"5\" />\n            <line x1=\"50\" y1=\"50\" x2=\"50\" y2=\"16\" stroke=\"#5a5a60\" stroke-width=\"4\" />\n            <line x1=\"50\" y1=\"50\" x2=\"82.3\" y2=\"60.5\" stroke=\"#5a5a60\" stroke-width=\"4\" />\n            <line x1=\"50\" y1=\"50\" x2=\"30\" y2=\"77.5\" stroke=\"#5a5a60\" stroke-width=\"4\" />\n            <line x1=\"50\" y1=\"50\" x2=\"17.7\" y2=\"39.5\" stroke=\"#5a5a60\" stroke-width=\"4\" />\n            <line x1=\"50\" y1=\"50\" x2=\"70\" y2=\"22.5\" stroke=\"#5a5a60\" stroke-width=\"4\" />\n            <circle cx=\"50\" cy=\"50\" r=\"9\" fill=\"#F9B646\" />\n        </g>\n        <circle class=\"sw-progress\" cx=\"50\" cy=\"50\" r=\"44\" />\n    </svg>\n</button>\n<div id=\"home\" class=\"home\">\n        <div class=\"homeContainer\"><header class=\"site-header\">\n    <a class=\"brand\" href=\"/\"><img src=\"/assets/logo.svg\" alt=\"vee logo\"></a>\n    <nav>\n        <ul>\n            <li><a href=\"/\" >Home</a></li>\n            <li><a href=\"/#intro\">Intro</a></li>\n            <li><a href=\"/projects\" >Projects</a></li>\n            <li><a href=\"/timeline\" >Timeline</a></li>\n            <li><a href=\"/chaicode\" >ChaiCode</a></li>\n            <li><a href=\"/blogs\" class=\"active\">Blogs</a></li>\n            <li><a href=\"/#contact\">Contact</a></li>\n            <li><a href=\"/#about\">About</a></li>\n        </ul>\n    </nav>\n    <div class=\"header-flag\"><img src=\"/assets/india.svg\" alt=\"Made in India\"></div>\n</header>\n\n            <!-- Single Blog Post Content -->\n            <div class=\"single-blog-container with-sidebar\">\n                <div class=\"back-link-wrapper mobile-back-link\">\n                    <a href=\"/blogs\" class=\"back-link\">\n                        <svg viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><path d=\"M19 12H5M12 19l-7-7 7-7\"/></svg>\n                        Back\n                    </a>\n                </div>\n                \n                <div class=\"blog-layout-grid\">\n                    <!-- Sticky Sidebar -->\n                    <aside class=\"blog-sidebar\">\n                        <div class=\"desktop-back-link\" style=\"margin-bottom: 20px;\">\n                            <a href=\"/blogs\" class=\"back-link\">\n                                <svg viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><path d=\"M19 12H5M12 19l-7-7 7-7\"/></svg>\n                                Back\n                            </a>\n                        </div>\n                        <div class=\"sidebar-inner\">\n                            <h3 class=\"sidebar-title\">On this page</h3>\n                            <nav class=\"table-of-contents\">\n                                <ul>\n                                    <li><a href=\"#introduction\" class=\"toc-link\">Introduction</a></li>\n                                    <li><a href=\"#basics\" class=\"toc-link\">The Basics</a></li>\n                                    <li><a href=\"#classes-ids\" class=\"toc-link\">Classes & IDs</a></li>\n                                    <li><a href=\"#nesting\" class=\"toc-link\">Nesting Elements</a></li>\n                                    <li><a href=\"#multiplication\" class=\"toc-link\">Multiplication</a></li>\n                                    <li><a href=\"#boilerplate\" class=\"toc-link\">Instant Boilerplate</a></li>\n                                </ul>\n                            </nav>\n                        </div>\n                    </aside>\n\n                    <!-- Main Article Content -->\n                    <div class=\"blog-main-content\">\n                        <header class=\"blog-header\">\n                            <h1>Emmet for HTML: A Beginner’s Guide to Writing Faster Markup</h1>\n                            <div class=\"blog-meta-row\">\n                                <div class=\"meta-category\">HTML & CSS</div>\n                                <div class=\"meta-author\">Veeshal D. Bodosa</div>\n                                <div class=\"meta-date\">27 Jan 2026</div>\n                            </div>\n                        </header>\n\n                        <div class=\"blog-hero-image-wrapper\">\n                            <img src=\"https://www.alphr.com/wp-content/uploads/2023/10/emmet-nedir-ve-ne-ise-yarar-1280x720.jpg\" alt=\"Emmet Logo\" class=\"blog-hero-image\" style=\"background: white; padding: 20px;\">\n                        </div>\n\n                        <article class=\"article-content\">\n                            <p class=\"lead\" id=\"introduction\">Typing HTML manually feels like a chore. Opening tags, typing the name, closing tags, typing the closing name... it is repetitive and error-prone. What if you could type a shorthand code and have it explode into full, valid HTML? That is exactly what Emmet does.</p>\n                            \n                            <p>Emmet is a plugin built into most modern code editors (like VS Code) that converts abbreviated syntax into full HTML structures instantly.</p>\n\n                            <div class=\"mermaid\">\n                            graph LR\n                                Short[Type: div.container] -->|Press Tab| Result[Result: &lt;div class='container'&gt;&lt;/div&gt;]\n                                style Short fill:#e1f5fe,stroke:#01579b\n                                style Result fill:#e8f5e9,stroke:#2e7d32\n                            </div>\n\n                            <h2 id=\"basics\">1. The Basics</h2>\n                            <p>At its simplest, type the tag name and press <code>Tab</code> or <code>Enter</code>.</p>\n                            \n                            <ul>\n                                <li>Type <code>h1</code> → <code>&lt;h1&gt;&lt;/h1&gt;</code></li>\n                                <li>Type <code>p</code> → <code>&lt;p&gt;&lt;/p&gt;</code></li>\n                                <li>Type <code>a</code> → <code>&lt;a href=\"\"&gt;&lt;/a&gt;</code></li>\n                            </ul>\n\n                            <h2 id=\"classes-ids\">2. Adding Classes and IDs</h2>\n                            <p>We use CSS selectors syntax here. <code>.</code> for Class and <code>#</code> for ID.</p>\n                            \n                            <div class=\"code-block\">\ndiv.card       →  &lt;div class=\"card\"&gt;&lt;/div&gt;\nh1#main-title  →  &lt;h1 id=\"main-title\"&gt;&lt;/h1&gt;\np.text-bold    →  &lt;p class=\"text-bold\"&gt;&lt;/p&gt;\n                            </div>\n\n                            <p>You can even combine them:</p>\n                            <div class=\"code-block\">\ndiv#hero.section.dark → &lt;div id=\"hero\" class=\"section dark\"&gt;&lt;/div&gt;\n                            </div>\n\n                            <h2 id=\"nesting\">3. Nesting Elements (The Child Operator)</h2>\n                            <p>Use the greater-than symbol <code>&gt;</code> to put one element inside another.</p>\n\n                            <div class=\"code-block\">\nul&gt;li&gt;a\n                            </div>\n\n                            <p><strong>Becomes:</strong></p>\n                            <div class=\"code-block\">\n&lt;ul&gt;\n    &lt;li&gt;\n        &lt;a href=\"\"&gt;&lt;/a&gt;\n    &lt;/li&gt;\n&lt;/ul&gt;\n                            </div>\n\n                            <div class=\"mermaid\">\n                            graph TD\n                                UL[ul] --> LI[li]\n                                LI --> A[a]\n                            </div>\n\n                            <h2 id=\"multiplication\">4. Multiplication (Repeating Elements)</h2>\n                            <p>Need a list with 5 items? Don't copy-paste. Use the asterisk <code>*</code>.</p>\n\n                            <div class=\"code-block\">\nul&gt;li*5\n                            </div>\n\n                            <p><strong>Becomes:</strong></p>\n                            <div class=\"code-block\">\n&lt;ul&gt;\n    &lt;li&gt;&lt;/li&gt;\n    &lt;li&gt;&lt;/li&gt;\n    &lt;li&gt;&lt;/li&gt;\n    &lt;li&gt;&lt;/li&gt;\n    &lt;li&gt;&lt;/li&gt;\n&lt;/ul&gt;\n                            </div>\n\n                            <h2 id=\"boilerplate\">5. The Ultimate Shortcut (Boilerplate)</h2>\n                            <p>Starting a new file? Just type <code>!</code> and press <code>Tab</code>.</p>\n                            \n                            <p>Emmet will generate the entire HTML5 document structure, including the <code>&lt;html&gt;</code>, <code>&lt;head&gt;</code>, <code>&lt;body&gt;</code>, and meta tags.</p>\n\n                            <div class=\"code-block\">\n&lt;!DOCTYPE html&gt;\n&lt;html lang=\"en\"&gt;\n&lt;head&gt;\n    &lt;meta charset=\"UTF-8\"&gt;\n    &lt;title&gt;Document&lt;/title&gt;\n&lt;/head&gt;\n&lt;body&gt;\n    \n&lt;/body&gt;\n&lt;/html&gt;\n                            </div>\n\n                            <h3>Conclusion</h3>\n                            <p>Emmet isn't cheating; it's efficiency. By memorizing these few patterns—<code>.</code> for classes, <code>&gt;</code> for nesting, and <code>*</code> for multiplication—you can write HTML as fast as you can think. Give it a try in your next project!</p>\n                        </article>\n                    </div>\n\n                    <!-- Right Sidebar (Tags) -->\n                    <aside class=\"blog-sidebar-right\">\n                        <div class=\"sidebar-tags-wrapper\">\n                            <h3 class=\"sidebar-title\">Tags</h3>\n                            <div class=\"blog-tags\">\n                                <a href=\"\" class=\"blog-tag\">#emmet</a>\n                                <a href=\"\" class=\"blog-tag\">#html</a>\n                                <a href=\"\" class=\"blog-tag\">#productivity</a>\n                                <a href=\"\" class=\"blog-tag\">#webdevcohort2026</a>\n                            </div>\n                        </div>\n                    </aside>\n        </div>\n    </div>\n    </div>\n\n    <!-- Footer -->\n    <footer class=\"site-footer\">\n    <div class=\"footer-top\">\n        <a class=\"brand\" href=\"/\"><img src=\"/assets/vee-logo-white.svg\" alt=\"vee logo\" onerror=\"this.src='/assets/logo.svg'\"></a>\n        <nav>\n            <ul>\n                <li><a href=\"/\">Home</a></li>\n                <li><a href=\"/#intro\">Intro</a></li>\n                <li><a href=\"/projects\">Projects</a></li>\n                <li><a href=\"/timeline\">Timeline</a></li>\n                <li><a href=\"/chaicode\">ChaiCode</a></li>\n                <li><a href=\"/blogs\">Blogs</a></li>\n                <li><a href=\"/#contact\">Contact</a></li>\n                <li><a href=\"/#about\">About</a></li>\n            </ul>\n        </nav>\n    </div>\n\n    <div class=\"footer-giant\">\n        <span class=\"row\"><span class=\"ghost\">fall back<span class=\"amber\">?</span></span></span>\n        <span class=\"row\"><span>redesign<span class=\"amber\">..!</span></span></span>\n    </div>\n\n    <div class=\"footer-bottom\">\n        <span>© 2026 veeshal d. bodosa</span>\n        <span>engineered with precision — crafted with passion</span>\n        <span><a href=