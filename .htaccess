Options +FollowSymLinks -MultiViews
RewriteEngine On

# 0. Remove index.php (Redirect to directory root)
RewriteCond %{THE_REQUEST} ^[A-Z]{3,}\s(.*)/index\.php[\s?] [NC]
RewriteRule ^(.*)index\.php$ $1 [R=301,L]

# 1. Remove .php extension
RewriteCond %{THE_REQUEST} ^[A-Z]{3,}\s([^.]+)\.php[\s?] [NC]
RewriteRule ^ %1 [R=301,L]

# 2. Internal rewrite (skip error pages)
RewriteCond %{REQUEST_URI} !/errors/
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME}.php -f
RewriteRule ^(.*)$ $1.php [L]

# Error Documents (Relative to the project folder for local XAMPP)
ErrorDocument 400 /veeshal/errors/400.php
ErrorDocument 403 /veeshal/errors/403.php
ErrorDocument 404 /veeshal/errors/404.php
ErrorDocument 500 /veeshal/errors/500.php
ErrorDocument 503 /veeshal/errors/503.php